# Solana
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet

# Asgard API Server
PORT=3000

# Security: Master password for AES-256-GCM key encryption at rest
# Generate with: openssl rand -hex 32
ASGARD_MASTER_PASSWORD=CHANGE_ME_use_openssl_rand_hex_32

# Kora Gas Abstraction Node URL
KORA_URL=http://localhost:8080

# Kora Sponsor wallet - this pays all Solana network fees for agents
# Fund this wallet with SOL on devnet: solana airdrop 2 <address> --url devnet
KORA_RPC_URL=http://localhost:8080/v1/rpc
KORA_HMAC_SECRET=kora_hmac_your-minimum-32-character-secret-here

# Optional: Path to keystore directory (default: ~/.asgard/keystore)
KEYSTORE_PATH=~/.asgard/keystore

# Optional: Admin API Key for provisioning new agents
ASGARD_ADMIN_KEY=CHANGE_ME_use_openssl_rand_hex_32
