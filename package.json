{
    "name": "asgard",
    "version": "1.0.0",
    "description": "Institutional-Grade Agentic Wallet-as-a-Service for AI Agents on Solana",
    "private": true,
    "workspaces": [
        "apps/*"
    ],
    "scripts": {
        "api": "npm run dev  --workspace=apps/api",
        "cli": "npm run start --workspace=apps/cli",
        "web": "npm run dev  --workspace=apps/webapp",
        "build": "npm run build --workspaces --if-present"
    },
    "engines": {
        "node": ">=18.0.0"
    }
}